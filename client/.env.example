# client/.env.example
# Copy this file to .env.local and fill in your deployed server URL.
#
# When building the Electron app, this URL is baked in at compile time via Vite's
# import.meta.env.VITE_DEDICATED_SERVER_URL.
#
# If this variable is not set, the client falls back to http://localhost:3001
# (useful for local development).

VITE_DEDICATED_SERVER_URL=https://your-server.onrender.com
