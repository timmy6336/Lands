{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@lands/shared": ["../shared/types.ts"],
      "@lands/game/*": ["../server/src/game/*"],
      "@lands/ai/*":   ["../server/src/ai/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*", "../shared/**/*", "../server/src/game/**/*", "../server/src/ai/**/*"]
}
