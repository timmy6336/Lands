{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "../dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".."
  },
  "include": [
    "../electron/**/*",
    "../server/src/**/*",
    "../shared/**/*"
  ],
  "exclude": ["../node_modules", "../client", "../dist"]
}
