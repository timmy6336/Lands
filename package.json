{
  "name": "lands",
  "version": "1.0.0",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently -n vite,tsc,electron -c blue,yellow,green \"cd client && npm run dev\" \"tsc -p electron/tsconfig.json --watch --preserveWatchOutput\" \"wait-on dist/electron/main.js && cross-env NODE_ENV=development electron .\"",
    "electron:build": "tsc -p electron/tsconfig.json && npm run build --prefix client",
    "build": "npm run electron:build && electron-builder",
    "package:zip": "npm run electron:build && electron-builder && powershell -Command \"Compress-Archive -Path 'release/win-unpacked/*' -DestinationPath 'release/Lands.zip' -Force\"",
    "install:all": "npm install && npm install --prefix client",
    "gen:cards": "node generate-cards.mjs"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "electron-serve": "^1.3.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "nat-api": "^0.3.1",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.5",
    "@types/uuid": "^9.0.7",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  }
}
