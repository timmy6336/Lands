{
  "appId": "com.lands.game",
  "productName": "Lands",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**",
    "node_modules/**",
    "package.json"
  ],
  "extraResources": [
    { "from": "client/dist", "to": "client/dist" },
    { "from": "resources",   "to": "resources"   }
  ],
  "extraFiles": [
    { "from": "README.md", "to": "README.md" }
  ],
  "win": {
    "target": [{ "target": "portable", "arch": ["x64"] }],
    "signingHashAlgorithms": null,
    "sign": null
  }
}
